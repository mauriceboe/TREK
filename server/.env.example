PORT=3001
JWT_SECRET=your-super-secret-jwt-key-change-in-production
NODE_ENV=development
APP_URL=http://localhost:3001
CONVEX_SITE_URL=https://your-deployment.convex.site
CONVEX_URL=https://your-deployment.convex.cloud
CONVEX_APPLICATION_ID=trek-web
CONVEX_AUTH_ISSUER_URL=http://localhost:3001/api/auth/convex
# Required for admin-authenticated Convex migration scripts
# CONVEX_DEPLOY_KEY=prod:your-deployment|secret
# Optional: provide your own persisted signing keys instead of server-managed files in ./server/data
# CONVEX_JWT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"
# CONVEX_JWT_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----"
